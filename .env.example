# ─────────────────────────────────────────────
#  PayNest — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# PostgreSQL — local example:
# Make sure PostgreSQL is running and you've created the DB:
#   createdb paynest
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/paynest"

# Redis — local example (just run: redis-server)
REDIS_URL="redis://localhost:6379"

# JWT — make this long and random, keep it secret!
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
